{
    "github.copilot.nextEditSuggestions.enabled": false,
    "github.copilot.nextEditSuggestions.eagerness": "low",

    "ltex.additionalRules.motherTongue": "de-DE",
    "ltex.completionEnabled": true,
    "ltex.language": "en-GB",

    "latex-workshop.latex.outDir": "%DIR%/build",
